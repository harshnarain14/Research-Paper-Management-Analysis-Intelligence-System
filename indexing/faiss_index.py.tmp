# This file is responsible for creating and managing a FAISS vector index
# FAISS is used for fast similarity search over embedding vectors

import faiss
import numpy as np


def create_faiss_index(embedded_chunks: list):
    """
    This function creates a FAISS index from embedded text chunks.

    At this stage:
    - We assume all embeddings have the same dimension
    - We use a simple flat (exact) index for clarity
    - We do NOT implement search yet
    """

    # Extract embeddings from chunks and convert to numpy array
    embeddings = [
        chunk["embedding"] for chunk in embedded_chunks
    ]

    # Convert list of embeddings to a NumPy array
    # FAISS requires float32 type
    embedding_matrix = np.array(embeddings).astype("float32")

    # Get embedding dimension (e.g., 384)
    dimension = embedding_matrix.shape[1]

    # Create a simple FAISS index using L2 (Euclidean) distance
    # IndexFlatL2 performs exact nearest neighbor search
    index = faiss.IndexFlatL2(dimension)

    # Add embeddings to the FAISS index
    index.add(n=embedding_matrix.shape[0], x=embedding_matrix)

    # Return the index and embeddings matrix
    return index, embedding_matrix
def semantic_search(
    query: str,
    model,
    index,
    chunks: list,
    top_k: int = 5
) -> list:
    """
    This function performs semantic search over the FAISS index.

    Steps:
    1. Convert user query into an embedding
    2. Search FAISS index for nearest vectors
    3. Map results back to original text chunks

    At this stage:
    - We return raw chunks
    - We do NOT use any LLM
    """

    # Generate embedding for the user query
    query_embedding = model.encode(query)

    # FAISS expects a 2D numpy array of type float32
    query_vector = query_embedding.astype("float32").reshape(1, -1)

    # Search the FAISS index
    # D = distances, I = indices of nearest neighbors
    distances, indices = index.search(query_vector, top_k)

    results = []

    # Map FAISS indices back to chunk metadata
    for idx in indices[0]:
        results.append(chunks[idx])

    return results
